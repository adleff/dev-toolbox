Host github-personal
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_personal
  IdentitiesOnly yes

Host github-rpl
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_rpl
  IdentitiesOnly yes

Host *
  ServerAliveInterval 60
  ServerAliveCountMax 3
  IdentitiesOnly yes
